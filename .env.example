# ====================================================================
# ==                ThinkTank Environment Variables                 ==
# ====================================================================
#
# This file serves as a template for the required environment variables.
# To get started, copy this file to a new file named `.env.local`:
#
#   cp .env.example .env.local
#
# Then, fill in the necessary values in your `.env.local` file.
# NOTE: `.env.local` is ignored by Git and should NEVER be committed.

# -- NextAuth.js Configuration --
# The full URL of your application, used for secure redirects.
NEXTAUTH_URL=http://localhost:3000

# A secret key used to sign and encrypt session data.
# This is a CRITICAL security value. Generate a strong, random key.
# You can generate a new one with the command: openssl rand -base64 32
NEXTAUTH_SECRET=any-random-string-here-for-development-mode-only


# -- ThinkTank Core Configuration --
# A 32-byte (64-character hex) key for encrypting sensitive data in config files (e.g., Git tokens).
# You can generate a new one with the command: openssl rand -hex 32
ENCRYPTION_KEY=

# The root directory where all project documentation is stored.
# If commented out, it defaults to the `docs` folder in the project root.
# DOCS_ROOT=
